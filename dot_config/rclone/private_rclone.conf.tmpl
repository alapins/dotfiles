[podus_alex]
type = sftp
host = podus
key_file = ~/.ssh/id_rsa
# key_use_agent = true
shell_type = unix
md5sum_command = md5sum
sha1sum_command = sha1sum

[plexus_alex]
type = sftp
host = plexus
key_file = ~/.ssh/id_rsa
# key_use_agent = true
shell_type = unix
md5sum_command = md5sum
sha1sum_command = sha1sum

[servus_root]
type = sftp
host = servus
user = root
key_file = ~/.ssh/id_rsa
# key_use_agent = true
shell_type = unix
md5sum_command = md5sum
sha1sum_command = sha1sum

[podus]
type = alias
remote = podus_alex:/

[plexus]
type = alias
remote = plexus_alex:/

[servus]
type = alias
remote = servus_root:/mnt/user

{{- if stdinIsATTY }}
[gdrive]
type = drive
client_id = {{ keepassxcAttribute "rclone-gdrive-keys" "client_id" }}
client_secret = {{ keepassxcAttribute "rclone-gdrive-keys" "client_secret" }}
scope = drive
token = {"access_token":"{{ keepassxcAttribute "rclone-gdrive-keys" "access_token" }}","token_type":"Bearer","refresh_token":"{{ keepassxcAttribute "rclone-gdrive-keys" "refresh_token" }}","expiry":"2026-04-11T22:58:48.802660153-04:00","expires_in":3599}
team_drive =
{{- else }}
# [gdrive] omitted: KeePassXC requires an interactive TTY to unlock.
# Re-run `chezmoi apply` from an interactive terminal to populate it.
{{- end }}

